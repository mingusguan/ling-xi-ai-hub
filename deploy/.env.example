# Copy this file to .env on the production server and edit real values there.

IMAGE_REPOSITORY=registry.cn-hangzhou.aliyuncs.com/mingus/lingxi-ai-hub
IMAGE_TAG=replace-with-github-sha

APP_PORT=8080
SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=-Xms256m -Xmx768m -XX:+UseG1GC
TZ=Asia/Shanghai

# If MySQL and Redis run on the Docker host, keep host.docker.internal.
MYSQL_URL=jdbc:mysql://host.docker.internal:3306/lingxi?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowMultiQueries=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=change-me

REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=change-me

FILE_STORAGE=cos
FILE_PATH=/app/uploadPath
FILE_DOMAIN=http://127.0.0.1:8080

DASHSCOPE_API_KEY=
SENIVERSE_WEATHER_API_KEY=

TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_SESSION_TOKEN=
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=
TENCENT_COS_DOMAIN=
TENCENT_COS_VECTOR_BUCKET=
TENCENT_COS_VECTOR_INDEX=kb_embedding
TENCENT_COS_VECTOR_DOMAIN=

KNOWLEDGE_VECTOR_STORE=cos-vector

# Set empty to skip curl health check in deploy.sh.
HEALTH_URL=http://127.0.0.1:8080/actuator/health
HEALTH_RETRY=30
HEALTH_INTERVAL=3
