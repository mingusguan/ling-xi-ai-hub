<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:flowable="http://flowable.org/bpmn" xmlns:lx="http://lingxi.com/schema/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://lingxi.com/oa/process">

  <bpmn:process id="oa_expense_approval" isExecutable="true" lx:formFields="[{&quot;code&quot;:&quot;expenseType&quot;,&quot;label&quot;:&quot;报销类型&quot;,&quot;type&quot;:&quot;select&quot;,&quot;required&quot;:true,&quot;displayStage&quot;:&quot;both&quot;,&quot;approveReadonly&quot;:true,&quot;options&quot;:[{&quot;value&quot;:&quot;travel&quot;,&quot;label&quot;:&quot;差旅&quot;},{&quot;value&quot;:&quot;entertain&quot;,&quot;label&quot;:&quot;招待&quot;},{&quot;value&quot;:&quot;office&quot;,&quot;label&quot;:&quot;办公&quot;}]},{&quot;code&quot;:&quot;amount&quot;,&quot;label&quot;:&quot;报销金额&quot;,&quot;type&quot;:&quot;number&quot;,&quot;required&quot;:true,&quot;displayStage&quot;:&quot;both&quot;,&quot;approveReadonly&quot;:false,&quot;options&quot;:[]},{&quot;code&quot;:&quot;expenseDate&quot;,&quot;label&quot;:&quot;费用日期&quot;,&quot;type&quot;:&quot;date&quot;,&quot;required&quot;:true,&quot;displayStage&quot;:&quot;both&quot;,&quot;approveReadonly&quot;:false,&quot;options&quot;:[]},{&quot;code&quot;:&quot;expenseReason&quot;,&quot;label&quot;:&quot;报销事由&quot;,&quot;type&quot;:&quot;textarea&quot;,&quot;required&quot;:true,&quot;displayStage&quot;:&quot;both&quot;,&quot;approveReadonly&quot;:false,&quot;options&quot;:[]}]" name="报销审批">

    <bpmn:startEvent id="StartEvent_1" name="发起报销">

      <bpmn:outgoing>Flow_1</bpmn:outgoing>

    </bpmn:startEvent>

    <bpmn:userTask flowable:assignee="${applicantUserId}" id="Activity_Edit" name="修改申请重新提交">

      <bpmn:incoming>Flow_Reject_Back_Manager</bpmn:incoming>

      <bpmn:incoming>Flow_Reject_Back_Finance</bpmn:incoming>

      <bpmn:incoming>Flow_Reject_Back_Admin</bpmn:incoming>

      <bpmn:incoming>Flow_Reject_Back_GM</bpmn:incoming>

      <bpmn:outgoing>Flow_To_Choice</bpmn:outgoing>

    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_Edit_Choice" name="选择操作"/>

    <bpmn:sequenceFlow id="Flow_To_Choice" sourceRef="Activity_Edit" targetRef="Gateway_Edit_Choice"/>

    <bpmn:userTask flowable:candidateGroups="manager" id="Activity_Manager" lx:approverType="role" lx:approverValue="manager" lx:needDeptFilter="true" name="部门负责人审批">

      <bpmn:incoming>Flow_1</bpmn:incoming>

      <bpmn:outgoing>Flow_Gateway_Manager</bpmn:outgoing>

    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_Manager_Approve" name="是否通过">

      <bpmn:incoming>Flow_Gateway_Manager</bpmn:incoming>

      <bpmn:outgoing>Flow_2</bpmn:outgoing>

    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_ExpenseType">

      <bpmn:incoming>Flow_2</bpmn:incoming>

      <bpmn:outgoing>Flow_3</bpmn:outgoing>

      <bpmn:outgoing>Flow_4</bpmn:outgoing>

      <bpmn:outgoing>Flow_5</bpmn:outgoing>

    </bpmn:exclusiveGateway>

    <bpmn:userTask flowable:candidateGroups="finance" id="Activity_Finance" lx:approverType="role" lx:approverValue="finance" lx:needDeptFilter="false" name="财务复核">

      <bpmn:incoming>Flow_3</bpmn:incoming>

      <bpmn:incoming>Flow_4</bpmn:incoming>

      <bpmn:outgoing>Flow_Gateway_Finance</bpmn:outgoing>

    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_Finance_Approve" name="是否通过">

      <bpmn:incoming>Flow_Gateway_Finance</bpmn:incoming>

      <bpmn:outgoing>Flow_0kzwf6d</bpmn:outgoing>

    </bpmn:exclusiveGateway>

    <bpmn:userTask flowable:candidateGroups="administration" id="Activity_Administration" lx:approverType="role" lx:approverValue="administration" lx:needDeptFilter="false" name="行政核验">

      <bpmn:incoming>Flow_5</bpmn:incoming>

      <bpmn:outgoing>Flow_Gateway_Admin</bpmn:outgoing>

    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_Admin_Approve" name="是否通过">

      <bpmn:incoming>Flow_Gateway_Admin</bpmn:incoming>

      <bpmn:outgoing>Flow_7</bpmn:outgoing>

    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_Amount" name="金额是否大于5000">

      <bpmn:incoming>Flow_7</bpmn:incoming>

      <bpmn:incoming>Flow_0kzwf6d</bpmn:incoming>

      <bpmn:outgoing>Flow_8</bpmn:outgoing>

      <bpmn:outgoing>Flow_9</bpmn:outgoing>

    </bpmn:exclusiveGateway>

    <bpmn:userTask flowable:candidateGroups="general_manager" id="Activity_Gm" lx:approverType="role" lx:approverValue="general_manager" lx:needDeptFilter="false" name="总经理审批">

      <bpmn:incoming>Flow_8</bpmn:incoming>

      <bpmn:outgoing>Flow_Gateway_GM</bpmn:outgoing>

    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_GM_Approve" name="是否通过">

      <bpmn:incoming>Flow_Gateway_GM</bpmn:incoming>

      <bpmn:outgoing>Flow_0qe36j5</bpmn:outgoing>

    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Success" name="审批完成">

      <bpmn:incoming>Flow_9</bpmn:incoming>

      <bpmn:incoming>Flow_0qe36j5</bpmn:incoming>

    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Cancelled" name="已取消"/>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Activity_Manager"/>

    <bpmn:sequenceFlow id="Flow_Resubmit" name="重新提交" sourceRef="Gateway_Edit_Choice" targetRef="Activity_Manager">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${action == null || action == 'resubmit'}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Cancel" name="取消申请" sourceRef="Gateway_Edit_Choice" targetRef="EndEvent_Cancelled">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${action == 'cancel'}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Gateway_Manager" sourceRef="Activity_Manager" targetRef="Gateway_Manager_Approve"/>

    <bpmn:sequenceFlow id="Flow_2" name="类型分流" sourceRef="Gateway_Manager_Approve" targetRef="Gateway_ExpenseType">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Reject_Back_Manager" name="否" sourceRef="Gateway_Manager_Approve" targetRef="Activity_Edit">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!approved}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_3" lx:conditionSummary="差旅报销进入财务复核" name="差旅" sourceRef="Gateway_ExpenseType" targetRef="Activity_Finance">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${expenseType == 'travel'}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_4" lx:conditionSummary="招待报销进入财务复核" name="招待" sourceRef="Gateway_ExpenseType" targetRef="Activity_Finance">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${expenseType == 'entertain'}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_5" lx:conditionSummary="办公报销先走行政核验" name="办公" sourceRef="Gateway_ExpenseType" targetRef="Activity_Administration">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${expenseType == 'office'}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Gateway_Finance" sourceRef="Activity_Finance" targetRef="Gateway_Finance_Approve"/>

    <bpmn:sequenceFlow id="Flow_Reject_Back_Finance" name="否" sourceRef="Gateway_Finance_Approve" targetRef="Activity_Edit">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!approved}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Gateway_Admin" sourceRef="Activity_Administration" targetRef="Gateway_Admin_Approve"/>

    <bpmn:sequenceFlow id="Flow_7" sourceRef="Gateway_Admin_Approve" targetRef="Gateway_Amount">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Reject_Back_Admin" name="否" sourceRef="Gateway_Admin_Approve" targetRef="Activity_Edit">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!approved}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_8" lx:conditionSummary="金额大于5000，进入总经理审批" sourceRef="Gateway_Amount" targetRef="Activity_Gm">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${amount &gt; 5000}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_9" lx:conditionSummary="金额不超过5000，复核后直接结束" name="否" sourceRef="Gateway_Amount" targetRef="EndEvent_Success">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${amount &lt;= 5000}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_Gateway_GM" sourceRef="Activity_Gm" targetRef="Gateway_GM_Approve"/>

    <bpmn:sequenceFlow id="Flow_Reject_Back_GM" name="否" sourceRef="Gateway_GM_Approve" targetRef="Activity_Edit">

      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${!approved}</bpmn:conditionExpression>

    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_0kzwf6d" sourceRef="Gateway_Finance_Approve" targetRef="Gateway_Amount"/>

    <bpmn:sequenceFlow id="Flow_0qe36j5" sourceRef="Gateway_GM_Approve" targetRef="EndEvent_Success"/>

  </bpmn:process>

