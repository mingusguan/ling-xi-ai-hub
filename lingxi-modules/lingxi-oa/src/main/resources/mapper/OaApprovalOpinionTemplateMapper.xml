<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lingxi.oa.mapper.OaApprovalOpinionTemplateMapper">

    <resultMap type="OaApprovalOpinionTemplate" id="OaApprovalOpinionTemplateResult">
        <id     property="templateId"          column="template_id"          />
        <result property="businessType"        column="business_type"        />
        <result property="templateContent"     column="template_content"     />
        <result property="riskLevel"           column="risk_level"           />
        <result property="enabled"             column="enabled"              />
    </resultMap>

    <select id="selectEnabledList" resultMap="OaApprovalOpinionTemplateResult">
        SELECT template_id, business_type, template_content, risk_level, enabled
        FROM oa_approval_opinion_template
        WHERE enabled = '1'
          AND (business_type = #{businessType} OR business_type = 'all')
        ORDER BY sort_order ASC
    </select>

</mapper>
