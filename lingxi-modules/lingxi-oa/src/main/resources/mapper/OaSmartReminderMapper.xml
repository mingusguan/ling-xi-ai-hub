<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lingxi.oa.mapper.OaSmartReminderMapper">

    <resultMap type="OaSmartReminder" id="OaSmartReminderResult">
        <id     property="reminderId"        column="reminder_id"        />
        <result property="userId"            column="user_id"            />
        <result property="reminderType"      column="reminder_type"      />
        <result property="title"             column="title"              />
        <result property="content"           column="content"            />
        <result property="businessType"      column="business_type"      />
        <result property="businessId"        column="business_id"        />
        <result property="priority"          column="priority"           />
        <result property="status"            column="status"             />
        <result property="sendTime"          column="send_time"          />
        <result property="readTime"          column="read_time"          />
    </resultMap>

    <sql id="selectOaSmartReminderVo">
        SELECT reminder_id, user_id, reminder_type, title, content, business_type,
               business_id, priority, status, send_time, read_time,
               create_by, create_time, update_by, update_time, remark
        FROM oa_smart_reminder
    </sql>

    <select id="selectOaSmartReminderList" parameterType="OaSmartReminder" resultMap="OaSmartReminderResult">
        <include refid="selectOaSmartReminderVo"/>
        <where>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="reminderType != null and reminderType != ''">AND reminder_type = #{reminderType}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        ORDER BY send_time DESC
    </select>

    <select id="selectOaSmartReminderById" parameterType="Long" resultMap="OaSmartReminderResult">
        <include refid="selectOaSmartReminderVo"/>
        WHERE reminder_id = #{reminderId}
    </select>

    <insert id="insertOaSmartReminder" parameterType="OaSmartReminder" useGeneratedKeys="true" keyProperty="reminderId">
        INSERT INTO oa_smart_reminder
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="reminderType != null">reminder_type,</if>
            <if test="title != null">title,</if>
            <if test="content != null">content,</if>
            <if test="businessType != null">business_type,</if>
            <if test="businessId != null">business_id,</if>
            <if test="priority != null">priority,</if>
            <if test="status != null">status,</if>
            <if test="sendTime != null">send_time,</if>
            <if test="readTime != null">read_time,</if>
            create_time
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="reminderType != null">#{reminderType},</if>
            <if test="title != null">#{title},</if>
            <if test="content != null">#{content},</if>
            <if test="businessType != null">#{businessType},</if>
            <if test="businessId != null">#{businessId},</if>
            <if test="priority != null">#{priority},</if>
            <if test="status != null">#{status},</if>
            <if test="sendTime != null">#{sendTime},</if>
            <if test="readTime != null">#{readTime},</if>
            NOW()
        </trim>
    </insert>

    <update id="updateOaSmartReminder" parameterType="OaSmartReminder">
        UPDATE oa_smart_reminder
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="reminderType != null">reminder_type = #{reminderType},</if>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="businessType != null">business_type = #{businessType},</if>
            <if test="businessId != null">business_id = #{businessId},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sendTime != null">send_time = #{sendTime},</if>
            <if test="readTime != null">read_time = #{readTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = NOW(),
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        WHERE reminder_id = #{reminderId}
    </update>

    <delete id="deleteOaSmartReminderById" parameterType="Long">
        DELETE FROM oa_smart_reminder WHERE reminder_id = #{reminderId}
    </delete>

</mapper>
