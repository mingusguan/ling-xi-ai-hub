<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lingxi.system.mapper.SysSubsystemMapper">
	
	<resultMap type="SysSubsystem" id="SysSubsystemResult">
		<id     property="subsystemId"    column="subsystem_id"    />
		<result property="subsystemCode"  column="subsystem_code"  />
		<result property="subsystemName"  column="subsystem_name"  />
		<result property="orderNum"       column="order_num"       />
		<result property="status"         column="status"          />
		<result property="createBy"       column="create_by"       />
		<result property="createTime"     column="create_time"     />
		<result property="updateBy"       column="update_by"       />
		<result property="updateTime"     column="update_time"     />
		<result property="remark"         column="remark"          />
	</resultMap>
	
	<sql id="selectSubsystemVo">
        select subsystem_id, subsystem_code, subsystem_name, order_num, status, create_by, create_time, update_by, update_time, remark 
		from sys_subsystem
    </sql>
	
	<select id="selectSubsystemList" parameterType="SysSubsystem" resultMap="SysSubsystemResult">
	    <include refid="selectSubsystemVo"/>
		<where>
			<if test="subsystemCode != null and subsystemCode != ''">
				AND subsystem_code like concat('%', #{subsystemCode}, '%')
			</if>
			<if test="subsystemName != null and subsystemName != ''">
				AND subsystem_name like concat('%', #{subsystemName}, '%')
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
		</where>
		order by order_num asc
	</select>
	
	<select id="selectSubsystemById" parameterType="Long" resultMap="SysSubsystemResult">
		<include refid="selectSubsystemVo"/>
		where subsystem_id = #{subsystemId}
	</select>
	
	<select id="selectSubsystemByCode" parameterType="String" resultMap="SysSubsystemResult">
		<include refid="selectSubsystemVo"/>
		where subsystem_code = #{subsystemCode}
	</select>
	
	<select id="checkSubsystemCodeUnique" parameterType="String" resultMap="SysSubsystemResult">
		<include refid="selectSubsystemVo"/>
		where subsystem_code = #{subsystemCode} limit 1
	</select>
	
	<insert id="insertSubsystem" parameterType="SysSubsystem" useGeneratedKeys="true" keyProperty="subsystemId">
 		insert into sys_subsystem(
 			<if test="subsystemCode != null and subsystemCode != ''">subsystem_code,</if>
 			<if test="subsystemName != null and subsystemName != ''">subsystem_name,</if>
 			<if test="orderNum != null">order_num,</if>
 			<if test="status != null and status != ''">status,</if>
 			<if test="remark != null and remark != ''">remark,</if>
 			<if test="createBy != null and createBy != ''">create_by,</if>
 			create_time
 		)values(
 			<if test="subsystemCode != null and subsystemCode != ''">#{subsystemCode},</if>
 			<if test="subsystemName != null and subsystemName != ''">#{subsystemName},</if>
 			<if test="orderNum != null">#{orderNum},</if>
 			<if test="status != null and status != ''">#{status},</if>
 			<if test="remark != null and remark != ''">#{remark},</if>
 			<if test="createBy != null and createBy != ''">#{createBy},</if>
 			sysdate()
 		)
	</insert>
	
	<update id="updateSubsystem" parameterType="SysSubsystem">
 		update sys_subsystem
 		<set>
 			<if test="subsystemCode != null and subsystemCode != ''">subsystem_code = #{subsystemCode},</if>
 			<if test="subsystemName != null and subsystemName != ''">subsystem_name = #{subsystemName},</if>
 			<if test="orderNum != null">order_num = #{orderNum},</if>
 			<if test="status != null and status != ''">status = #{status},</if>
 			<if test="remark != null">remark = #{remark},</if>
 			<if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
 			update_time = sysdate()
 		</set>
 		where subsystem_id = #{subsystemId}
	</update>
	
	<delete id="deleteSubsystemById" parameterType="Long">
		delete from sys_subsystem where subsystem_id = #{subsystemId}
	</delete>
	
	<delete id="deleteSubsystemByIds" parameterType="Long">
 		delete from sys_subsystem where subsystem_id in 
 		<foreach item="subsystemId" collection="array" open="(" separator="," close=")">
 			#{subsystemId}
        </foreach> 
 	</delete>

</mapper>
