<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lingxi.ai.mapper.AiChatMessageMapper">

    <resultMap type="com.lingxi.ai.domain.AiChatMessage" id="AiChatMessageResult">
        <id property="messageId" column="message_id"/>
        <result property="sessionId" column="session_id"/>
        <result property="role" column="role"/>
        <result property="content" column="content"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectBySessionId" resultMap="AiChatMessageResult">
        SELECT message_id, session_id, role, content, create_time
        FROM ai_chat_message
        WHERE session_id = #{sessionId}
        ORDER BY create_time ASC
    </select>

    <insert id="insert" parameterType="com.lingxi.ai.domain.AiChatMessage" useGeneratedKeys="true" keyProperty="messageId">
        INSERT INTO ai_chat_message (session_id, role, content, create_time)
        VALUES (#{sessionId}, #{role}, #{content}, #{createTime})
    </insert>

    <delete id="deleteBySessionId">
        DELETE FROM ai_chat_message WHERE session_id = #{sessionId}
    </delete>

</mapper>
