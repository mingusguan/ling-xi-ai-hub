<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lingxi.ai.mapper.MindmapMapper">
    
    <resultMap type="com.lingxi.ai.domain.Mindmap" id="MindmapResult">
        <id     property="mindmapId"    column="mindmap_id"    />
        <result property="title"        column="title"         />
        <result property="description"  column="description"   />
        <result property="userPrompt"   column="user_prompt"   />
        <result property="dataJson"     column="data_json"     />
        <result property="layoutType"   column="layout_type"   />
        <result property="theme"        column="theme"         />
        <result property="nodeCount"    column="node_count"    />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectMindmapVo">
        select mindmap_id, title, description, user_prompt, data_json, layout_type, theme, node_count, status, create_by, create_time, update_by, update_time, remark from sys_mindmap
    </sql>

    <select id="selectMindmapList" parameterType="com.lingxi.ai.domain.Mindmap" resultMap="MindmapResult">
        <include refid="selectMindmapVo"/>
        <where>  
            <if test="title != null  and title != ''"> and title like concat('%', #{title}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="createBy != null  and createBy != ''"> and create_by = #{createBy}</if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectMindmapById" parameterType="Long" resultMap="MindmapResult">
        <include refid="selectMindmapVo"/>
        where mindmap_id = #{mindmapId}
    </select>
        
    <insert id="insertMindmap" parameterType="com.lingxi.ai.domain.Mindmap" useGeneratedKeys="true" keyProperty="mindmapId">
        insert into sys_mindmap
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="description != null">description,</if>
            <if test="userPrompt != null">user_prompt,</if>
            <if test="dataJson != null">data_json,</if>
            <if test="layoutType != null">layout_type,</if>
            <if test="theme != null">theme,</if>
            <if test="nodeCount != null">node_count,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="description != null">#{description},</if>
            <if test="userPrompt != null">#{userPrompt},</if>
            <if test="dataJson != null">#{dataJson},</if>
            <if test="layoutType != null">#{layoutType},</if>
            <if test="theme != null">#{theme},</if>
            <if test="nodeCount != null">#{nodeCount},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateMindmap" parameterType="com.lingxi.ai.domain.Mindmap">
        update sys_mindmap
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="userPrompt != null">user_prompt = #{userPrompt},</if>
            <if test="dataJson != null">data_json = #{dataJson},</if>
            <if test="layoutType != null">layout_type = #{layoutType},</if>
            <if test="theme != null">theme = #{theme},</if>
            <if test="nodeCount != null">node_count = #{nodeCount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where mindmap_id = #{mindmapId}
    </update>

    <delete id="deleteMindmapById" parameterType="Long">
        delete from sys_mindmap where mindmap_id = #{mindmapId}
    </delete>

    <delete id="deleteMindmapByIds" parameterType="String">
        delete from sys_mindmap where mindmap_id in 
        <foreach item="mindmapId" collection="array" open="(" separator="," close=")">
            #{mindmapId}
        </foreach>
    </delete>
</mapper>
